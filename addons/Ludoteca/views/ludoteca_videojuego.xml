<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Acciones -->
    <record id='ludoteca_videojuego_action' model='ir.actions.act_window'>
        <field name="name">Videojuegos</field>
        <field name="res_model">ludoteca.videojuego</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id='ludoteca_desarrollador_action' model='ir.actions.act_window'>
        <field name="name">Desarrolladores</field>
        <field name="res_model">ludoteca.desarrollador</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id='ludoteca_plataforma_action' model='ir.actions.act_window'>
        <field name="name">Plataformas</field>
        <field name="res_model">ludoteca.plataforma</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id='ludoteca_genero_action' model='ir.actions.act_window'>
        <field name="name">Géneros</field>
        <field name="res_model">ludoteca.genero</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menús -->
    <menuitem name="Ludoteca" id="ludoteca_menu" sequence="10"/>
    
    <menuitem 
        name="Catálogo" 
        id="ludoteca_catalogo_menu" 
        parent="ludoteca_menu" 
        sequence="10"/>
    
    <menuitem 
        name="Desarrolladores" 
        id="ludoteca_desarrollador_menu" 
        parent="ludoteca_catalogo_menu" 
        action="ludoteca_desarrollador_action"
        sequence="10"/>
    
    <menuitem 
        name="Plataformas" 
        id="ludoteca_plataforma_menu" 
        parent="ludoteca_catalogo_menu" 
        action="ludoteca_plataforma_action"
        sequence="20"/>
    
    <menuitem 
        name="Géneros" 
        id="ludoteca_genero_menu" 
        parent="ludoteca_catalogo_menu" 
        action="ludoteca_genero_action"
        sequence="30"/>
    
    <menuitem 
        name="Videojuegos" 
        id="ludoteca_videojuego_menu" 
        parent="ludoteca_menu" 
        action="ludoteca_videojuego_action"
        sequence="20"/>

    <!-- Vistas Videojuego -->
    <record id="ludoteca_videojuego_view_form" model="ir.ui.view">
        <field name="name">Videojuego - Formulario</field>
        <field name="model">ludoteca.videojuego</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="nombre" placeholder="Título del juego"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Información básica">
                            <field name="desarrollador_id" widget="selection"/>
                            <field name="fecha_lanzamiento"/>
                            <field name="precio"/>
                            <field name="estado"/>
                        </group>
                        <group string="Clasificación">
                            <field name="genero_ids" widget="many2many_tags"/>
                            <field name="plataforma_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Sinopsis">
                            <field name="descripcion" placeholder="Describe la historia y mecánicas del juego..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ludoteca_videojuego_view_list" model="ir.ui.view">
        <field name="name">Videojuego - Lista</field>
        <field name="model">ludoteca.videojuego</field>
        <field name="arch" type="xml">
            <list>
                <field name="nombre"/>
                <field name="desarrollador_id"/>
                <field name="genero_ids" widget="many2many_tags"/>
                <field name="plataforma_ids" widget="many2many_tags"/>
                <field name="fecha_lanzamiento"/>
                <field name="precio"/>
            </list>
        </field>
    </record>

    <!-- Vistas Desarrollador -->
    <record id="ludoteca_desarrollador_view_form" model="ir.ui.view">
        <field name="name">Desarrollador - Formulario</field>
        <field name="model">ludoteca.desarrollador</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="nombre" placeholder="Nombre del estudio"/>
                        </h1>
                    </div>
                    
                    <group>
                        <field name="pais"/>
                    </group>
                    
                    <notebook>
                        <page string="Videojuegos desarrollados">
                            <field name="videojuegos_ids">
                                <list>
                                    <field name="nombre"/>
                                    <field name="genero_ids" widget="many2many_tags"/>
                                    <field name="plataforma_ids" widget="many2many_tags"/>
                                    <field name="fecha_lanzamiento"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ludoteca_desarrollador_view_list" model="ir.ui.view">
        <field name="name">Desarrollador - Lista</field>
        <field name="model">ludoteca.desarrollador</field>
        <field name="arch" type="xml">
            <list>
                <field name="nombre"/>
                <field name="pais"/>
            </list>
        </field>
    </record>

    <!-- Vistas Plataforma -->
    <record id="ludoteca_plataforma_view_form" model="ir.ui.view">
        <field name="name">Plataforma - Formulario</field>
        <field name="model">ludoteca.plataforma</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="nombre" placeholder="Nombre de la plataforma"/>
                        </h1>
                    </div>
                    
                    <group>
                        <field name="fabricante"/>
                    </group>
                    
                    <notebook>
                        <page string="Catálogo de juegos">
                            <field name="videojuegos_ids">
                                <list>
                                    <field name="nombre"/>
                                    <field name="desarrollador_id"/>
                                    <field name="genero_ids" widget="many2many_tags"/>
                                    <field name="fecha_lanzamiento"/>
                                    <field name="precio"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ludoteca_plataforma_view_list" model="ir.ui.view">
        <field name="name">Plataforma - Lista</field>
        <field name="model">ludoteca.plataforma</field>
        <field name="arch" type="xml">
            <list>
                <field name="nombre"/>
                <field name="fabricante"/>
            </list>
        </field>
    </record>

    <!-- Vistas Género -->
    <record id="ludoteca_genero_view_form" model="ir.ui.view">
        <field name="name">Género - Formulario</field>
        <field name="model">ludoteca.genero</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="nombre" placeholder="Nombre del género"/>
                        </h1>
                    </div>
                    
                    <group>
                        <field name="descripcion" nolabel="1"/>
                    </group>
                    
                    <notebook>
                        <page string="Videojuegos de este género">
                            <field name="videojuegos_ids">
                                <list>
                                    <field name="nombre"/>
                                    <field name="desarrollador_id"/>
                                    <field name="plataforma_ids" widget="many2many_tags"/>
                                    <field name="fecha_lanzamiento"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ludoteca_genero_view_list" model="ir.ui.view">
        <field name="name">Género - Lista</field>
        <field name="model">ludoteca.genero</field>
        <field name="arch" type="xml">
            <list>
                <field name="nombre"/>
            </list>
        </field>
    </record>

</odoo>