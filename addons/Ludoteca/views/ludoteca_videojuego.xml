<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Acciones -->
    <record id='ludoteca_videojuego_action' model='ir.actions.act_window'>
        <field name="name">Videojuegos</field>
        <field name="res_model">ludoteca.videojuego</field>
        <field name="view_mode">kanban,calendar,list,form,graph</field>  <!-- ✅ Añadimos calendar -->
        <field name="search_view_id" ref="ludoteca_videojuego_view_search"/>
    </record>

    <record id='ludoteca_desarrollador_action' model='ir.actions.act_window'>
        <field name="name">Desarrolladores</field>
        <field name="res_model">ludoteca.desarrollador</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id='ludoteca_plataforma_action' model='ir.actions.act_window'>
        <field name="name">Plataformas</field>
        <field name="res_model">ludoteca.plataforma</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id='ludoteca_genero_action' model='ir.actions.act_window'>
        <field name="name">Géneros</field>
        <field name="res_model">ludoteca.genero</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menús -->
    <menuitem name="Ludoteca" id="ludoteca_menu" sequence="10"/>
    
    <menuitem 
        name="Catálogo" 
        id="ludoteca_catalogo_menu" 
        parent="ludoteca_menu" 
        sequence="10"/>
    
    <menuitem 
        name="Desarrolladores" 
        id="ludoteca_desarrollador_menu" 
        parent="ludoteca_catalogo_menu" 
        action="ludoteca_desarrollador_action"
        sequence="10"/>
    
    <menuitem 
        name="Plataformas" 
        id="ludoteca_plataforma_menu" 
        parent="ludoteca_catalogo_menu" 
        action="ludoteca_plataforma_action"
        sequence="20"/>
    
    <menuitem 
        name="Géneros" 
        id="ludoteca_genero_menu" 
        parent="ludoteca_catalogo_menu" 
        action="ludoteca_genero_action"
        sequence="30"/>
    
    <menuitem 
        name="Videojuegos" 
        id="ludoteca_videojuego_menu" 
        parent="ludoteca_menu" 
        action="ludoteca_videojuego_action"
        sequence="20"/>

    <!-- Vistas Videojuego -->
    <record id="ludoteca_videojuego_view_form" model="ir.ui.view">
        <field name="name">Videojuego - Form</field>
        <field name="model">ludoteca.videojuego</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Botones con sintaxis Odoo 17+ -->
                    <button name="action_publish" 
                            string="Publish" 
                            type="object" 
                            class="btn-success"
                            invisible="estado != 'borrador'"/>
                    <button name="action_set_draft" 
                            string="Set Draft" 
                            type="object" 
                            class="btn-secondary"
                            invisible="estado == 'borrador'"/>
                    <button name="%(ludoteca_time_wizard_action)d" 
                            string="⏱ Log Time" 
                            type="action" 
                            class="btn-primary"
                            context="{'default_task_id': active_id}"
                            invisible="estado == 'descatalogado'"/>
                    <field name="estado" widget="statusbar" readonly="1"/>
                </header>
                
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="nombre" placeholder="Game Title"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Basic Information">
                            <field name="desarrollador_id" widget="selection"/>
                            <field name="fecha_lanzamiento" invisible="estado == 'borrador'"/>
                            <field name="precio" readonly="estado in ['agotado', 'descatalogado']"/>
                            <field name="progress" widget="progressbar"/>
                            <field name="total_hours" sum="Total Hours"/>
                        </group>
                        <group string="Classification">
                            <field name="genero_ids" widget="many2many_tags"/>
                            <field name="plataforma_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Synopsis">
                            <field name="descripcion" placeholder="Describe the story and mechanics..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ludoteca_videojuego_view_list" model="ir.ui.view">
        <field name="name">Videojuego - List</field>
        <field name="model">ludoteca.videojuego</field>
        <field name="arch" type="xml">
            <list decoration-info="estado == 'borrador'" 
                  decoration-success="estado == 'disponible'" 
                  decoration-warning="estado == 'agotado'" 
                  decoration-danger="estado == 'descatalogado'">
                <field name="nombre"/>
                <field name="desarrollador_id"/>
                <field name="genero_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                <field name="plataforma_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                <field name="fecha_lanzamiento"/>
                <field name="precio" sum="Total Price"/>
                <field name="calificacion" sum="Avg Rating"/>
                <field name="estado" widget="badge" decoration-info="estado == 'borrador'" decoration-success="estado == 'disponible'" decoration-warning="estado == 'agotado'" decoration-danger="estado == 'descatalogado'"/>
            </list>
        </field>
    </record>

        <!-- Vista Calendar: Videojuego (para mostrar deadlines/fechas de lanzamiento) -->
    <record id="ludoteca_videojuego_view_calendar" model="ir.ui.view">
        <field name="name">Videojuego - Calendar</field>
        <field name="model">ludoteca.videojuego</field>
        <field name="arch" type="xml">
            <calendar date_start="fecha_lanzamiento" 
                      color="desarrollador_id"
                      mode="month"
                      quick_add="False"
                      event_open_string="Ver Videojuego">
                <field name="nombre"/>
                <field name="estado"/>
                <field name="precio"/>
                <field name="desarrollador_id"/>
            </calendar>
        </field>
    </record>

    <!-- Vistas Desarrollador -->
    <record id="ludoteca_desarrollador_view_form" model="ir.ui.view">
        <field name="name">Desarrollador - Formulario</field>
        <field name="model">ludoteca.desarrollador</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="nombre" placeholder="Game Studio name"/>
                        </h1>
                    </div>
                    
                    <group>
                        <field name="pais"/>
                    </group>
                    
                    <notebook>
                        <page string="Videojuegos desarrollados">
                            <field name="videojuegos_ids">
                                <list>
                                    <field name="nombre"/>
                                    <field name="genero_ids" widget="many2many_tags"/>
                                    <field name="plataforma_ids" widget="many2many_tags"/>
                                    <field name="fecha_lanzamiento"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ludoteca_desarrollador_view_list" model="ir.ui.view">
        <field name="name">Desarrollador - Lista</field>
        <field name="model">ludoteca.desarrollador</field>
        <field name="arch" type="xml">
            <list>
                <field name="nombre"/>
                <field name="pais"/>
            </list>
        </field>
    </record>

    <!-- Vistas Plataforma -->
    <record id="ludoteca_plataforma_view_form" model="ir.ui.view">
        <field name="name">Plataforma - Formulario</field>
        <field name="model">ludoteca.plataforma</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="nombre" placeholder="Platform name"/>
                        </h1>
                    </div>
                    
                    <group>
                        <field name="fabricante"/>
                    </group>
                    
                    <notebook>
                        <page string="Catálogo de juegos">
                            <field name="videojuegos_ids">
                                <list>
                                    <field name="nombre"/>
                                    <field name="desarrollador_id"/>
                                    <field name="genero_ids" widget="many2many_tags"/>
                                    <field name="fecha_lanzamiento"/>
                                    <field name="precio"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ludoteca_plataforma_view_list" model="ir.ui.view">
        <field name="name">Plataforma - Lista</field>
        <field name="model">ludoteca.plataforma</field>
        <field name="arch" type="xml">
            <list>
                <field name="nombre"/>
                <field name="fabricante"/>
            </list>
        </field>
    </record>

    <!-- Vistas Género -->
    <record id="ludoteca_genero_view_form" model="ir.ui.view">
        <field name="name">Género - Formulario</field>
        <field name="model">ludoteca.genero</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="nombre" placeholder="Genre name"/>
                        </h1>
                    </div>
                    
                    <group>
                        <field name="descripcion" nolabel="1"/>
                    </group>
                    
                    <notebook>
                        <page string="Videojuegos de este género">
                            <field name="videojuegos_ids">
                                <list>
                                    <field name="nombre"/>
                                    <field name="desarrollador_id"/>
                                    <field name="plataforma_ids" widget="many2many_tags"/>
                                    <field name="fecha_lanzamiento"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ludoteca_genero_view_list" model="ir.ui.view">
        <field name="name">Género - Lista</field>
        <field name="model">ludoteca.genero</field>
        <field name="arch" type="xml">
            <list>
                <field name="nombre"/>
            </list>
        </field>
    </record>

</odoo>